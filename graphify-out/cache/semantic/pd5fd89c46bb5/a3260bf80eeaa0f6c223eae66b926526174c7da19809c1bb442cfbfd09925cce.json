{"nodes": [{"id": "_claude_skills_graphify_skill_graphify", "label": "graphify", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graphify_query", "label": "graphify query command", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graphify_path", "label": "graphify path command", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graphify_explain", "label": "graphify explain command", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graphify_add", "label": "graphify add command", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_watch_flag", "label": "--watch flag", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_update_flag", "label": "--update flag", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_cluster_only_flag", "label": "--cluster-only flag", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_deep_mode", "label": "--mode deep", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Requests thorough extraction with aggressive INFERRED edges (indirect deps, shared assumptions, latent couplings); uncertain ones are marked AMBIGUOUS instead of omitted, trading recall for a wider audit surface."}, {"id": "_claude_skills_graphify_skill_directed_flag", "label": "--directed flag", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_ast_extraction", "label": "AST structural extraction (Part A)", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deterministic and free (no LLM, no API key) - a code-only corpus can skip semantic extraction entirely and rely on AST alone, run in parallel with semantic subagents to save 5-15s on large corpora."}, {"id": "_claude_skills_graphify_skill_semantic_extraction", "label": "Semantic extraction (Part B)", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Only needed for docs/papers/images. Uses Gemini if GEMINI_API_KEY/GOOGLE_API_KEY is set, otherwise falls back to the host agent itself as the LLM via dispatched subagents - graphify never reads ANTHROPIC_API_KEY or other provider keys and must never block on a missing one."}, {"id": "_claude_skills_graphify_skill_extraction_cache", "label": "Semantic extraction cache (Step B0)", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cache entries are keyed to the extraction-spec prompt file (SPEC_PATH) so that when the prompt changes (a graphify upgrade), stale entries are re-extracted instead of replayed, while unchanged prompts keep their cached entries (#1939)."}, {"id": "_claude_skills_graphify_skill_graph_report", "label": "GRAPH_REPORT.md", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_graph_json", "label": "graph.json", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_shrink_guard", "label": "Shrink-guard (#479)", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "to_json() refuses to write graph.json when the new graph is smaller than the existing one, so a bad/partial extraction can never silently clobber a good graph.json, GRAPH_REPORT.md, or analysis sidecar."}, {"id": "_claude_skills_graphify_skill_health_check", "label": "Graph health check (Step 4.5)", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Read-only, non-aborting diagnostic that surfaces edge collapse, dangling/missing endpoints, and self-loops - the silent-corruption modes of incremental updates and AST/LLM id mismatches - so integrity issues stay visible without blocking the pipeline."}, {"id": "_claude_skills_graphify_skill_honesty_rules", "label": "Honesty Rules", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_cost_tracker", "label": "Cumulative cost tracker (cost.json)", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_god_nodes", "label": "god_nodes analysis", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_gemini_backend", "label": "Gemini semantic backend", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "_claude_skills_graphify_skill_graphify_add", "target": "_claude_skills_graphify_references_add_watch_ingest", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_skill_watch_flag", "target": "_claude_skills_graphify_references_add_watch_watch_mechanism", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_skill_graphify", "target": "_claude_skills_graphify_references_exports_wiki", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_