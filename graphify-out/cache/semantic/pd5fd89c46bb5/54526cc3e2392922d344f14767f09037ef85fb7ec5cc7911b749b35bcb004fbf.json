{"nodes": [{"id": "_claude_skills_graphify_references_query_vocab_expansion", "label": "Constrained query expansion (Step 0)", "file_type": "rationale", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The graphify query CLI matches nodes via case-folded substring + IDF with no stemming, synonyms, or cross-language matching, so a wording mismatch between the user's question and the graph's node-label vocabulary collapses the answer to noise; the fix is to expand the query against the graph's own extracted vocabulary first, picking only tokens that already exist in it rather than inventing near-synonyms."}, {"id": "_claude_skills_graphify_references_query_bfs_mode", "label": "BFS traversal mode", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_references_query_dfs_mode", "label": "DFS traversal mode", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_references_query_save_result", "label": "save-result feedback command", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_references_query_work_memory", "label": "Work memory / self-improving loop (--outcome)", "file_type": "rationale", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tagging save-result with --outcome useful/dead_end/corrected lets future sessions learn: useful answers become preferred sources, dead ends are skipped instead of re-derived, and corrections record the right answer - closing a feedback loop across sessions."}, {"id": "_claude_skills_graphify_references_query_reflect", "label": "graphify reflect / LESSONS.md", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_references_query_path_flow", "label": "/graphify path flow", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_references_query_explain_flow", "label": "/graphify explain flow", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "_claude_skills_graphify_references_query_work_memory", "target": "_claude_skills_graphify_references_query_reflect", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_references_query_path_flow", "target": "_claude_skills_graphify_skill_graphify_path", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_references_query_explain_flow", "target": "_claude_skills_graphify_skill_graphify_explain", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "weight": 1.0}], "hyperedges": []