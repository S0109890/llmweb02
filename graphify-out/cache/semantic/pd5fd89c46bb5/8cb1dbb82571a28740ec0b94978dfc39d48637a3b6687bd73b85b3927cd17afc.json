{"nodes": [{"id": "_claude_skills_graphify_references_update_incremental", "label": "--update incremental re-extraction flow", "file_type": "concept", "source_file": ".claude/skills/graphify/references/update.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_references_update_code_only_shortcut", "label": "Code-only update shortcut", "file_type": "rationale", "source_file": ".claude/skills/graphify/references/update.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "When every changed file in an --update run is a code file, semantic extraction (subagents) is skipped entirely and only AST re-extraction runs, since code-only changes need no LLM."}, {"id": "_claude_skills_graphify_references_update_build_merge", "label": "build_merge()", "file_type": "rationale", "source_file": ".claude/skills/graphify/references/update.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reads graph.json directly without a NetworkX round-trip so edge direction (calls/implements/imports) is always preserved (#801); every source_file present in the new extraction is dropped from the base graph before merging, so re-extracted (changed) files replace their stale nodes instead of being deduplicated after the fact (#1344), while prune_sources is reserved strictly for genuinely deleted files."}, {"id": "_claude_skills_graphify_references_update_cluster_only", "label": "--cluster-only flow", "file_type": "concept", "source_file": ".claude/skills/graphify/references/update.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_references_update_graph_diff", "label": "graph_diff (old vs new comparison)", "file_type": "concept", "source_file": ".claude/skills/graphify/references/updat